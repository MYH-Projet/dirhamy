# ==============================================================================
# DIRHAMY: Environment Variables Configuration
# ==============================================================================
# Renommez ce fichier en `.env` avant de lancer l'application localement
# ==============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL with pgvector via Prisma)
# Replace with your actual username/password and host if running outside Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dirhamy

# Redis Configuration (For Caching layer)
REDIS_URL=127.0.0.1
REDIS_PASSWORD=your_redis_password_here

# Security & Authentication (JWT Secrets)
# Use mathematically complex strings for these in production
JWT_SECRET=your_super_secret_jwt_key
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key

# Third-Party AI Integrations
# Required for Budget Insights and Chatbot functionalites
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Email Delivery Configuration (Nodemailer/Cron Jobs)
GMAIL=your_business_email@gmail.com
GMAIL_PASS=your_gmail_app_password
